# =============================================================================
# .env.example
# Mutual Fund FAQ Assistant — Environment variable template
#
# Copy to .env for local development:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# ---- LLM Provider (Phase 3) ------------------------------------------------
# Required for Groq LLM mode. If unset, falls back to extractive mode.
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use. Options:
#   llama-3.1-8b-instant  (faster, lower cost)
#   mixtral-8x7b-32768    (higher quality)
GROQ_MODEL=llama-3.1-8b-instant

# ---- Optional: OpenAI embedding fallback (Phase 1.5) -----------------------
# Only used if OPENAI_API_KEY is set. Falls back to bge-small-en if unset.
OPENAI_API_KEY=

# ---- Application (Phase 4) -------------------------------------------------
# Host and port for the FastAPI server
APP_HOST=0.0.0.0
APP_PORT=8000

# Allowed CORS origin for the frontend (e.g. Vercel deployment URL)
# Use * only for local dev; never in production.
CORS_ALLOWED_ORIGIN=http://localhost:3000

# ---- Paths -----------------------------------------------------------------
# Override default config and data directories (useful for Docker volume mounts)
CONFIG_DIR=./config
DATA_DIR=./data

# ---- Logging ---------------------------------------------------------------
LOG_LEVEL=INFO
