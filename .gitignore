# =============================================================================
# .gitignore — Mutual Fund FAQ Assistant
# =============================================================================

# ---- Secrets ---------------------------------------------------------------
.env
*.key

# ---- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
*.pyc

# ---- Data (never commit raw HTML, vectors, or indexes) ---------------------
data/raw/
data/chunks/
data/index/

# ---- Model cache -----------------------------------------------------------
.cache/
models/

# ---- IDE -------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ---- OS -------------------------------------------------------------------
.DS_Store
Thumbs.db

# ---- pytest ----------------------------------------------------------------
.pytest_cache/
htmlcov/
.coverage

# ---- Logs ------------------------------------------------------------------
logs/
*.log
